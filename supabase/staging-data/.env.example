# Copy this file to .env in the same folder and fill in the secret values.
# .env is gitignored; .env.example is committed — DO NOT paste real secrets here.

# --- Supabase (staging project: xeqjairmlwnjtmselyvo) ---
SUPABASE_URL=https://xeqjairmlwnjtmselyvo.supabase.co
# Dashboard → Project Settings → API → row labeled "service_role" (secret).
# NOT the anon or publishable keys.
SUPABASE_SERVICE_ROLE_KEY=

# --- Webflow (GetInsyt site: 6996e7ba74bd91bb800cf26f) ---
# Webflow → Workspace Settings → Apps & Integrations → API access.
# Create a Site API token with CMS read+write scope on the GetInsyt site.
# This is a SEPARATE copy from the token used by the sync-creator-to-webflow
# edge function (that one lives as a Supabase secret).
WEBFLOW_API_TOKEN=
WEBFLOW_CREATORS_COLLECTION_ID=6a0ae123ed5b01902ba61136
WEBFLOW_INSYTS_COLLECTION_ID=69d23ea82129dff2b2dc134d
WEBFLOW_SITE_ID=6996e7ba74bd91bb800cf26f

# --- Test user password ---
# Applied to every non-anchor seeded test account. Pick once, document in
# your password manager, share with anyone running Playwright tests.
SEED_USER_PASSWORD=

# --- Stripe (TEST mode) ---
# Stripe Dashboard → Developers → API keys → "Secret key" while the
# dashboard toggle is in Test mode. Starts with `sk_test_...`.
# Used by the seed to create real Product/Price/PaymentLink objects so
# the staging checkout flow can actually call Stripe end-to-end.
STRIPE_SECRET_KEY=
